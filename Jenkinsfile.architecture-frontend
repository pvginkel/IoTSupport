// Architecture producer pipeline for the federated Architecture-as-Code model.
// Frontend producer (lives under frontend/ in the monorepo).
// Source of truth: the hand-authored frontend/docs/architecture/*.yaml in this repo.
// The agent needs outbound HTTPS to architecture.webathome.org for validation.

library identifier: 'JenkinsPipelineUtils', changelog: false

podTemplate(inheritFrom: 'jenkins-agent', containers: [
    containerTemplates.python('python')
]) {
    node(POD_LABEL) {
        stage('Cloning repo') {
            checkout scm
        }

        stage('Architecture') {
            dir('frontend') {
                container('python') {
                    sh './scripts/arch-validate.py docs/architecture/*.yaml'
                }
            }
            archiveArtifacts artifacts: 'frontend/docs/architecture/*.yaml', fingerprint: true
        }
    }
}
